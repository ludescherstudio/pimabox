# Dashboard URLs — all three lead to the same place
RewriteEngine On
RewriteRule ^pimabox$   pimabox.php [L]
RewriteRule ^analytics$ pimabox.php [L]

# Block direct access to config and cache
<Files "config.php">
    Order Allow,Deny
    Deny from all
</Files>

# Recommended: prevent directory listing
Options -Indexes
